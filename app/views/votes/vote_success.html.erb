<div class="col d-flex justify-content-center align-items-center min-vh-50 py-5">
  <div class="card shadow-sm border-0" style="max-width: 480px;">
    <div class="card-body text-center p-4 p-md-5">
      <div class="mb-3">
        <%= image_tag 'evoting.png', width: 120, class: 'img-fluid', alt: 'eVoting' %>
      </div>

      <div class="d-inline-flex align-items-center justify-content-center rounded-circle bg-success bg-opacity-10 text-success mb-3" style="width: 64px; height: 64px;">
        <i class="bi bi-check-circle-fill" style="font-size: 2rem;"></i>
      </div>

      <h4 class="text-success fw-bold mb-2">Your vote was saved successfully</h4>
      <p class="text-muted mb-4">Thank you for participating in our electronic voting.</p>

      <hr class="my-4">

      <%
=begin%>
 <p class="text-muted small mb-3">You can return to the voting page to review or change your choices.</p> 
<%
=end%>
      <%= link_to voter_code_path(p: @event), class: 'link-success' do %>
        <i class="bi bi-arrow-left-circle me-2"></i>
        Back to vote
      <% end %>
    </div>
  </div>
</div>
