<div class="home-page">
  <header class="home-hero">
    <%= image_tag 'evoting.png', class: 'home-hero__logo', alt: 'e-Voting' %>
    <h1 class="home-hero__title">Current voting event</h1>
    <p class="home-hero__subtitle">View the active event below and cast your vote when the election is open.</p>
  </header>

  <% if @event.present? %>
    <section class="event-single">
      <article class="event-card event-card--single">
        <div class="event-card__body">
          <div class="event-card__header">
            <h2 class="event-card__title"><%= @event.name %></h2>
            <%= link_to event_path(@event), class: 'event-card__settings', title: 'Event settings', aria: { label: 'Event settings' } do %>
              <i class="bi bi-gear"></i>
            <% end %>
          </div>
          <% if @event.description.present? %>
            <p class="event-card__description"><%= @event.description %></p>
          <% end %>
          <div class="event-card__badges">
            <% if @event.election %>
              <span class="badge badge--success"><i class="bi bi-check-circle me-1"></i>Election open</span>
            <% else %>
              <span class="badge badge--muted"><i class="bi bi-lock me-1"></i>Election closed</span>
            <% end %>
            <% if @event.active %>
              <span class="badge badge--success"><i class="bi bi-circle-fill me-1"></i>Active</span>
            <% else %>
              <span class="badge badge--muted">Disabled</span>
            <% end %>
          </div>
          <% if @event.election %>
            <%= link_to voter_code_path(p: @event), class: 'event-card__cta btn btn-primary' do %>
              <i class="bi bi-box-arrow-in-right me-2"></i>Vote now
            <% end %>
          <% else %>
            <span class="event-card__cta event-card__cta--disabled" aria-disabled="true">
              <i class="bi bi-lock me-2"></i>Voting closed
            </span>
          <% end %>
        </div>
      </article>
    </section>
  <% else %>
    <section class="events-empty">
      <div class="events-empty__content">
        <i class="bi bi-calendar-x events-empty__icon"></i>
        <h2 class="events-empty__title">No events available</h2>
        <p class="events-empty__text">There are no active voting events at the moment. Check back later or contact your administrator.</p>
      </div>
    </section>
  <% end %>
</div>
